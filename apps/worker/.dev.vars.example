INTERNAL_WORKER_TO_VPS=replace-me
SESSION_SIGNING_KEY=replace-me
REGISTRATION_CODE=replace-me
DEV_LOGIN_TOKEN='dev-only-paste-this-to-login'

# Uncomment to run against the local agent HTTP server (`pnpm dev:agent:server` on :3000)
# instead of the production tunnel:
# VPS_ORIGIN=http://localhost:3000

# Uncomment for browser-based passkey testing on localhost (origin is the vite
# dev server at :5173, which proxies /auth/* + /api/* to the worker at :8787):
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_ORIGIN=http://localhost:5173
