# Local dev secrets for the agent CLI (`pnpm dev:agent`) and HTTP server (`pnpm dev:agent:server`).
# Copy to .env and fill in real values. Never commit the .env file.

# Anthropic API key (sk-ant-...). The SDK calls Anthropic directly with this.
ANTHROPIC_API_KEY=sk-ant-...

# Local Postgres for memory bin scripts (memory-append.mjs, db-query.mjs).
DATABASE_URL=postgres://agent:agent@localhost:5432/agent

# Shared token between the Worker and the agent HTTP server.
# Must match the same key in apps/worker/.dev.vars and the Workers Secret of the same name.
INTERNAL_WORKER_TO_VPS=replace-me
